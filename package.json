{
  "name": "lucid-memory",
  "version": "0.1.0",
  "description": "CLI-first unified memory layer for AI agents",
  "type": "module",
  "bin": {
    "lucid": "./bin/lucid.ts"
  },
  "scripts": {
    "dev": "bun bin/lucid.ts",
    "test": "bun test",
    "build": "bun build bin/lucid.ts --outdir dist --target node",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "memory",
    "cli",
    "agent",
    "llm",
    "semantic-search",
    "curation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Vikang/lucid"
  },
  "homepage": "https://github.com/Vikang/lucid",
  "author": "Victoria Wang",
  "license": "MIT",
  "engines": {
    "bun": ">=1.0.0"
  },
  "files": [
    "bin/",
    "src/",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@google/generative-ai": "^0.24.1",
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "openai": "^6.29.0",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.9.0"
  }
}
